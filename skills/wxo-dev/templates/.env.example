# watsonx Orchestrate Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# ==============================================================================
# REQUIRED: Choose ONE Authentication Method
# ==============================================================================

# Option 1: watsonx Orchestrate Account (SaaS/Trial)
# Use this for cloud-based watsonx Orchestrate instances
WO_DEVELOPER_EDITION_SOURCE=orchestrate
WO_INSTANCE=https://your-instance.watson-orchestrate.ibm.com
WO_API_KEY=your-api-key-here

# Option 2: myIBM (On-premises/Purchased)
# Use this for on-premises or purchased watsonx Orchestrate
# WO_DEVELOPER_EDITION_SOURCE=myibm
# WO_ENTITLEMENT_KEY=your-entitlement-key
# GROQ_API_KEY=your-groq-api-key
# WATSONX_APIKEY=your-watsonx-api-key
# WATSONX_SPACE_ID=your-space-id

# Option 3: Custom Image Registry
# Use this for custom container registries
# WO_DEVELOPER_EDITION_SOURCE=custom
# REGISTRY_URL=your-registry-url
# REGISTRY_USERNAME=your-username
# REGISTRY_PASSWORD=your-password

# ==============================================================================
# OPTIONAL: Service Credentials
# ==============================================================================
# Developer Edition includes built-in services (Minio, Langfuse, MCP Gateway)
# Only override if using external services

# Minio (Object Storage)
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin

# Langfuse (Observability)
# LANGFUSE_SECRET_KEY=your-secret-key
# LANGFUSE_PUBLIC_KEY=your-public-key

# MCP Gateway
# MCP_GATEWAY_API_KEY=your-api-key

# ==============================================================================
# OPTIONAL: Regional Configuration
# ==============================================================================
# For non-us-south regions, configure regional endpoints

# ASSISTANT_LLM_API_BASE=https://us-south.ml.cloud.ibm.com
# ASSISTANT_EMBEDDINGS_API_BASE=https://us-south.ml.cloud.ibm.com
# ROUTING_LLM_API_BASE=https://us-south.ml.cloud.ibm.com
# WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ==============================================================================
# OPTIONAL: On-Premises Configuration
# ==============================================================================
# For on-premises deployments with Docker

# DOCKER_IMAGE_PULL_POLICY=IfNotPresent
# DOCKER_SKIP_SSL_VERIFY=false
# DOCKER_ENABLE_LAYER_CACHING=true

# ==============================================================================
# External API Keys (for connections)
# ==============================================================================
# Add your external service API keys here
# These are used by connection configurations

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Google
# GOOGLE_API_KEY=...

# Custom APIs
# CUSTOM_API_KEY=...
# CUSTOM_API_URL=https://api.example.com

# ==============================================================================
# Slack Integration (if using Slack channels)
# ==============================================================================
# SLACK_WORKSPACE_ID=your-workspace-id
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# ==============================================================================
# Microsoft Teams Integration (if using Teams channels)
# ==============================================================================
# TEAMS_APP_ID=your-app-id
# TEAMS_APP_PASSWORD=your-app-password

# ==============================================================================
# Database Configuration (if using external database)
# ==============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# DATABASE_POOL_SIZE=10

# ==============================================================================
# IMPORTANT NOTES
# ==============================================================================
# 1. Never commit this file with actual credentials
# 2. Use strong, unique passwords and API keys
# 3. Rotate credentials regularly
# 4. Use environment-specific .env files (.env.dev, .env.prod)
# 5. Ensure .env is in your .gitignore file